<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- HashMap Title -->
        <TextView
            android:id="@+id/hashmapTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:paddingBottom="6dp"/>

        <!-- Container for Key-Value Pairs -->
        <LinearLayout
            android:id="@+id/keyValueContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp"/>

        <!-- Buttons Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:paddingTop="8dp">

            <!-- Add Key-Value Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAddKeyValue"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:text="Add Content"
                android:textSize="14sp"
                android:background="@drawable/blk_stroke_btn"
                android:textColor="@color/black"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

            <!-- Delete HashMap Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDeleteHashMap"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:text="Delete"
                android:textSize="14sp"
                android:background="@drawable/delete_btn"
                android:textColor="@color/white"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
